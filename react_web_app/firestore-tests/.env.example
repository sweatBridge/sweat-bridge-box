# =============================================================================
# firestore-tests/.env  (이 파일은 .env.example — 복사해서 .env로 만들고 값을 채우세요)
# =============================================================================
# live-smoke.js 가 prod Firestore에 직접 붙어 규칙을 검증할 때 사용한다.
# .env 는 .gitignore에 등록돼 있어 커밋되지 않는다 — 절대 git에 올리지 말 것.
# =============================================================================

# ── Firebase Web SDK 설정 ────────────────────────────────────────────────────
# Firebase Console → ⚙ Project Settings → "내 앱" → 웹 앱의 SDK 설정에서 복사.
# 또는 react_web_app/src/config/firebase.ts 의 firebaseConfig에서도 가져올 수 있다.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=sweat-bridge.firebaseapp.com
FIREBASE_PROJECT_ID=sweat-bridge

# ── 테스트 계정 (Firebase Auth에 수동 생성 + /user 문서도 생성 필요) ─────────
# 생성 방법: Firebase Console → Authentication → 사용자 추가
#           Firestore Console → /user 컬렉션에 이메일을 문서 ID로 사용
#
# qa-admin: { role: 'admin', boxName: '' }
ADMIN_EMAIL=qa-admin@sweat.test
ADMIN_PASSWORD=

# qa-coach: { role: 'coach', boxName: TEST_BOX }
COACH_EMAIL=qa-coach@sweat.test
COACH_PASSWORD=

# qa-member: { role: 'MEMBER', boxName: TEST_BOX }
# 또한 /box/TEST_BOX/member/qa-member@... 문서도 생성 (최소: email/realName/boxName)
MEMBER_EMAIL=qa-member@sweat.test
MEMBER_PASSWORD=

# ── 실제 박스 이름 (cross-tenant deny 검증용) ────────────────────────────────
# TEST_BOX: qa-coach / qa-member 가 속한 박스 (실제 prod 박스 중 하나)
# OTHER_BOX: 다른 박스 (코치/회원이 접근 못해야 하는 쪽)
TEST_BOX=SWEAT
OTHER_BOX=CFBD

# (선택) cross-user deny 검증용 — TEST_BOX의 다른 회원 이메일.
# 비워두면 L14 케이스만 스킵, 나머지는 정상 동작.
OTHER_MEMBER_EMAIL=
